#!/usr/bin/env bash
# e-clawhisper CLI wrapper — sets FHS paths and delegates to the Python entry point.
# Config resolution: $CONFIG_PATH > ~/.config/e-clawhisper > /etc/e-clawhisper > ./config.yaml
set -euo pipefail

export MODELS_DIR="${MODELS_DIR:-/opt/e-clawhisper/models}"
export DATA_DIR="${DATA_DIR:-/opt/e-clawhisper/data}"
export SOCKET_PATH="${SOCKET_PATH:-${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/e-clawhisper/eclaw.sock}"
export PYTHONPATH="/opt/e-clawhisper/src"

exec /opt/e-clawhisper/.venv/bin/python -m e_clawhisper.main "$@"
